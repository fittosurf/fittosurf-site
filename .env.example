# Brevo (Sendinblue) API credentials — copy this file to `.env` and fill in real values.
# The .env file is gitignored and must never be committed.

# Your Brevo API v3 key (Brevo dashboard → SMTP & API → API Keys)
BREVO_API_KEY=

# The numeric ID of the Brevo contact list to add subscribers to
BREVO_LIST_ID=
